# ═══════════════════════════════════════════════════════════════
# GED COURRIER - Configuration Docker (sans MongoDB)
# ═══════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et modifiez les valeurs
# Utilisez avec: docker-compose -f docker-compose.standalone.yml up -d

# ═══════════════════════════════════════════════════════════════
# MONGODB EXTERNE
# ═══════════════════════════════════════════════════════════════
# MongoDB installé sur l'hôte (Linux):
# MONGODB_URI=mongodb://host.docker.internal:27017/ged_courrier

# MongoDB installé sur l'hôte avec authentification:
# MONGODB_URI=mongodb://user:password@host.docker.internal:27017/ged_courrier?authSource=admin

# MongoDB sur un autre serveur:
# MONGODB_URI=mongodb://user:password@192.168.1.100:27017/ged_courrier?authSource=admin

MONGODB_URI=mongodb://host.docker.internal:27017/ged_courrier

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
# IMPORTANT: Générez un secret unique avec: openssl rand -base64 32
JWT_SECRET=VotreSecretJWT_TresLong_Minimum32Caracteres_AChangerEnProduction
JWT_EXPIRE=7d

# URL publique de l'application (avec https en production)
APP_URL=https://ged.mondomaine.com
APP_NAME=GED Courrier

# Domaines autorisés pour CORS (séparés par des virgules)
CORS_ORIGIN=https://ged.mondomaine.com

# Taille max des fichiers en octets (50MB par défaut)
MAX_FILE_SIZE=50000000

# ═══════════════════════════════════════════════════════════════
# SMTP - Envoi d'emails (optionnel mais recommandé)
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.exemple.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@mondomaine.com
SMTP_PASSWORD=VotreMotDePasseSMTP
SMTP_FROM=GED Courrier <no-reply@mondomaine.com>

# ═══════════════════════════════════════════════════════════════
# LDAP - Authentification annuaire (optionnel)
# ═══════════════════════════════════════════════════════════════
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.exemple.com:389
LDAP_BIND_DN=cn=admin,dc=exemple,dc=com
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=dc=exemple,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})

# ═══════════════════════════════════════════════════════════════
# KERBEROS - Authentification SSO (optionnel)
# ═══════════════════════════════════════════════════════════════
KERBEROS_ENABLED=false
KERBEROS_REALM=EXEMPLE.COM
KERBEROS_KDC=kdc.exemple.com
KERBEROS_SERVICE_PRINCIPAL=HTTP/ged.exemple.com@EXEMPLE.COM

# ═══════════════════════════════════════════════════════════════
# IMAP - Import automatique d'emails (optionnel)
# ═══════════════════════════════════════════════════════════════
IMAP_ENABLED=false
IMAP_HOST=imap.exemple.com
IMAP_PORT=993
IMAP_USER=courrier@exemple.com
IMAP_PASSWORD=
IMAP_TLS=true
IMAP_MAILBOX=INBOX
IMAP_PROCESSED_FOLDER=Traités
IMAP_CHECK_INTERVAL=5
