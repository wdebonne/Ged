# Configuration du serveur
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ged_courrier

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise_a_changer_en_production
JWT_EXPIRE=7d

# LDAP Configuration (optionnel)
LDAP_ENABLED=false
LDAP_URL=ldap://votre-serveur-ldap:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=votre_mot_de_passe
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})
# DN du groupe AD/LDAP dont les membres sont seuls autorisés à se connecter (optionnel)
# Laisser vide pour autoriser tous les utilisateurs LDAP authentifiés
# Ex: cn=GED,ou=group,dc=example,dc=com
LDAP_REQUIRED_GROUP_DN=

# Serveur LDAP/AD de secours (optionnel). Utilisé automatiquement à chaque connexion
# si le serveur principal (LDAP_URL) est inaccessible (NAS éteint, panne réseau).
# Laisser LDAP_URL_BACKUP vide pour désactiver le failover.
LDAP_URL_BACKUP=
LDAP_BIND_DN_BACKUP=
LDAP_BIND_PASSWORD_BACKUP=
# Optionnels : si vides, reprennent la valeur de la configuration principale ci-dessus
LDAP_SEARCH_BASE_BACKUP=
LDAP_SEARCH_FILTER_BACKUP=
LDAP_REQUIRED_GROUP_DN_BACKUP=

# Intervalle (en minutes) de vérification périodique de l'appartenance au groupe requis
# (LDAP_REQUIRED_GROUP_DN). Si un utilisateur LDAP n'est plus membre de ce groupe, son compte
# GED est désactivé (isActive=false) au cycle suivant : sa session active est coupée dès sa
# prochaine requête ("Compte désactivé"), sans attendre l'expiration du token ni une nouvelle
# connexion. Une seule requête LDAP par cycle, quel que soit le nombre d'utilisateurs.
# Sans effet si LDAP_REQUIRED_GROUP_DN n'est pas défini.
LDAP_GROUP_CHECK_INTERVAL=5

# Kerberos Configuration (optionnel)
KERBEROS_ENABLED=false
KERBEROS_REALM=EXAMPLE.COM
KERBEROS_KDC=kdc.example.com
KERBEROS_SERVICE_PRINCIPAL=HTTP/ged.example.com@EXAMPLE.COM

# IMAP Configuration (optionnel)
IMAP_ENABLED=false
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=courrier@example.com
IMAP_PASSWORD=votre_mot_de_passe
IMAP_TLS=true
IMAP_MAILBOX=INBOX
IMAP_PROCESSED_FOLDER=Traités
IMAP_CHECK_INTERVAL=5

# SMTP pour envoi de mails (reset password, notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=votre_mot_de_passe
SMTP_FROM=GED Courrier <no-reply@example.com>

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=50000000

# Application
APP_URL=http://localhost:5173
APP_NAME=GED Courrier

# CORS - Origines autorisées (séparées par des virgules)
# En production: CORS_ORIGIN=https://mondomaine.com,https://www.mondomaine.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
